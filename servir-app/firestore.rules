rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isAdmin() || request.auth.uid == uid;
    }

    match /teams/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /members/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    match /services/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /schedules/{id} {
      allow read: if true; // público para confirmação por link
      allow write: if isAuth();
    }

    match /forms/{id} {
      allow read: if true; // público para resposta
      allow write: if isAuth();
    }

    match /formResponses/{id} {
      allow read: if isAuth();
      allow create: if true; // público para submissão
    }
  }
}
